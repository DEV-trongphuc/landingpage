        <!-- Scripts for AI WOW interactions -->
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const mainWrapper = document.querySelector('main.ideas_main');
                if (!mainWrapper) return;
                mainWrapper.classList.add('js-ready-for-wow');

                // 1. Assign wow-item classes dynamically
                const selectorsToAnimate = [
                    '.ideas_img_side', '.ideas_main_title', '.ideas_des li',
                    '.ideas_numbers > div', '.ideas_benefits h3', '.ideas_benefits p',
                    '.ideas_courses h2', '.ideas_euromap_content li', '.ideas_euromap_img',
                    '.ideas_title_viewmore', '.ideas_event_snap', '.ideas_quote_school iframe',
                    '.ideas_text', '.ideas_quote h2', '.ideas_social_avatar',
                    '.ideas_title_center', '.ideas_coop_item', '.ideas_faq h2', '.ideas_faq_add'
                ];

                selectorsToAnimate.forEach(selector => {
                    document.querySelectorAll(selector).forEach((el, index) => {
                        el.classList.add('wow-item');
                        let delayClass = 'wow-delay-' + ((index % 5) + 1);
                        el.classList.add(delayClass);
                    });
                });

                // 2. Intersection Observer
                const observer = new IntersectionObserver((entries, obs) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('wow-visible');

                            // 3. Number Counter Animation Trigger
                            const counterTarget = entry.target.tagName === 'DIV'
                                && entry.target.closest('.ideas_numbers')
                                ? entry.target.querySelector('p[class$="_count"]')
                                : null;

                            if (counterTarget && !counterTarget.classList.contains('counted')) {
                                counterTarget.classList.add('counted');
                                let text = counterTarget.textContent;
                                let num = parseInt(text.replace(/[^0-9]/g, ''));
                                let suffix = text.replace(/[0-9]/g, '');
                                if (!isNaN(num)) {
                                    const duration = 2500;
                                    const startTime = performance.now();

                                    const updateCounter = (currentTime) => {
                                        const elapsed = currentTime - startTime;
                                        const progress = Math.min(elapsed / duration, 1);
                                        const easeProgress = 1 - Math.pow(1 - progress, 4);
                                        const currentNum = Math.floor(easeProgress * num);

                                        counterTarget.textContent = currentNum + suffix;

                                        if (progress < 1) {
                                            requestAnimationFrame(updateCounter);
                                        } else {
                                            counterTarget.textContent = num + suffix;
                                        }
                                    };
                                    requestAnimationFrame(updateCounter);
                                }
                            }

                            obs.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

                setTimeout(() => {
                    document.querySelectorAll('.wow-item').forEach(el => observer.observe(el));
                }, 100);

                // --- PREMIUM UI/UX UPGRADES ---

                // 1. Magnetic Buttons
                const magneticBtns = document.querySelectorAll('.main_btn, .test_btn');
                magneticBtns.forEach(btn => {
                    btn.addEventListener('mousemove', (e) => {
                        const rect = btn.getBoundingClientRect();
                        const x = e.clientX - rect.left;
                        const y = e.clientY - rect.top;

                        btn.style.setProperty('--x', `${x}px`);
                        btn.style.setProperty('--y', `${y}px`);

                        if (window.innerWidth > 768 && !window.matchMedia("(pointer: coarse)").matches) {
                            const centerX = rect.width / 2;
                            const centerY = rect.height / 2;
                            const pullX = (x - centerX) * 0.15;
                            const pullY = (y - centerY) * 0.15;
                            btn.style.transform = `translate(${pullX}px, ${pullY}px) scale(1.02)`;
                        }
                    });

                    btn.addEventListener('mouseleave', () => {
                        btn.style.transform = 'translate(0px, 0px) scale(1)';
                    });
                });

                // 2. 3D Tilt Effect
                const tiltItems = document.querySelectorAll('.ideas_numbers > div, .ideas_benefits p, .gallery_item');
                if (window.innerWidth > 768 && !window.matchMedia("(pointer: coarse)").matches) {
                    tiltItems.forEach(item => {
                        item.addEventListener('mousemove', (e) => {
                            const rect = item.getBoundingClientRect();
                            const x = e.clientX - rect.left;
                            const y = e.clientY - rect.top;

                            const centerX = rect.width / 2;
                            const centerY = rect.height / 2;

                            const rotateX = ((y - centerY) / centerY) * -8;
                            const rotateY = ((x - centerX) / centerX) * 8;

                            item.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;

                            const glareOpacity = Math.max(0, 0.4 - (y / rect.height) * 0.4);
                            item.style.setProperty('--glare-opacity', glareOpacity);
                        });

                        item.addEventListener('mouseleave', () => {
                            item.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
                            item.style.setProperty('--glare-opacity', '0');
                        });
                    });
                }

                // 3. Smooth Parallax
                const parallaxItems = document.querySelectorAll('.euro_map, .phapts, .pattern_totnghiep');
                if (window.innerWidth > 768) {
                    window.addEventListener('scroll', () => {
                        const scrolled = window.pageYOffset;
                        parallaxItems.forEach((item, index) => {
                            const speed = 0.05 + (index * 0.02);
                            const yPos = -(scrolled * speed);
                            item.style.setProperty('--parallax-y', `${yPos}px`);
                        });
                    }, { passive: true });
                }

            });
        </script>

        <style>
            /* --- PREMIUM UI/UX UPGRADES CSS --- */

            /* Magnetic Buttons Glow */
            .main_btn,
            .test_btn {
                position: relative;
                overflow: hidden;
                transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.3s ease !important;
                will-change: transform;
            }

            .main_btn::before,
            .test_btn::before {
                content: '';
                position: absolute;
                top: var(--y, 50%);
                left: var(--x, 50%);
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.4) 0%, transparent 50%);
                transform: translate(-50%, -50%) scale(0);
                transition: transform 0.4s ease-out;
                pointer-events: none;
                z-index: 0;
            }

            .main_btn:hover::before,
            .test_btn:hover::before {
                transform: translate(-50%, -50%) scale(1);
            }

            .main_btn>*,
            .test_btn>* {
                position: relative;
                z-index: 1;
            }

            /* 3D Tilt Glare */
            .ideas_numbers>div,
            .ideas_benefits p,
            .gallery_item {
                transform-style: preserve-3d;
                perspective: 1000px;
                position: relative;
                will-change: transform;
            }

            .ideas_numbers>div::before,
            .ideas_benefits p::before,
            .gallery_item::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: linear-gradient(135deg, rgba(255, 255, 255, 0.5) 0%, transparent 60%);
                opacity: 0;
                transition: opacity 0.3s ease;
                pointer-events: none;
                z-index: 10;
                border-radius: inherit;
            }

            .ideas_numbers>div:hover::before,
            .ideas_benefits p:hover::before,
            .gallery_item:hover::before {
                opacity: var(--glare-opacity, 0);
            }

            /* Premium Text Clip Reveal */
            .ideas_main_title,
            .ideas_courses h2,
            .ideas_quote h2,
            .ideas_faq h2,
            .ideas_title_viewmore h2 {
                transform: translateY(30px);
                opacity: 0;
                transition: transform 1.2s cubic-bezier(0.25, 1, 0.2, 1), opacity 0.6s ease;
            }

            .wow-visible.ideas_main_title,
            h2.wow-visible {
                transform: translateY(0);
                opacity: 1;
            }

            /* Parallax Float Override */
            @keyframes float-parallax {
                0% {
                    transform: translateY(calc(var(--parallax-y, 0px) + 0px));
                }

                50% {
                    transform: translateY(calc(var(--parallax-y, 0px) - 15px));
                }

                100% {
                    transform: translateY(calc(var(--parallax-y, 0px) + 0px));
                }
            }

            .pattern_totnghiep {
                animation: float-parallax 6s ease-in-out infinite !important;
                will-change: transform;
            }
        </style>
    </main>
